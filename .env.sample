# Azure OpenAI Configuration
# Copy this file to .env and fill in your values
#
# Registration required for GPT-5.4 access: https://aka.ms/OAI/gpt53codexaccess
# Auth: uses DefaultAzureCredential (az login, managed identity, etc.)
#
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4               # Your deployment name for gpt-5.4
