# ── APIM gateway (required) ───────────────────────────────────────────
# Full base URL of your APIM gateway API, e.g.:
#   https://my-apim.azure-api.net/aoai
# Do NOT include /openai/v1/ — config.py appends that automatically.
APIM_ENDPOINT=https://YOUR_APIM_NAME.azure-api.net/YOUR_API_SUFFIX

# APIM product/subscription key (found in APIM portal → Subscriptions)
APIM_SUBSCRIPTION_KEY=your-apim-subscription-key-here

# ── Model deployments (match names in your Foundry/AOAI resource) ─────
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_DEPLOYMENT_PRO=gpt-5.4-pro

# ── Direct AOAI endpoint (optional — only needed for gateway vs direct comparisons) ──
# AZURE_OPENAI_ENDPOINT=https://YOUR_AOAI_RESOURCE.openai.azure.com
